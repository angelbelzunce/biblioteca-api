spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/biblioteca
    username: postgres
    password: your_password_here
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  application:
    name: biblioteca-api

server:
  port: 8080

 jwt:
   secret: your_secret_key_here_minimum_32_characters_long
   expiration: 86400000